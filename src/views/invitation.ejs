<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Parisienne&family=Playfair+Display:ital,wght@0,400;0,700;1,700&family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/invitation.css">
</head>
<body class="invitation-page">
    <div class="sobre-overlay" id="sobreOverlay" aria-hidden="false">
        <div class="sobre" id="sobreBtn" role="button" tabindex="0" aria-label="Abrir invitación">
            <h2>Dayana &amp; Exio</h2>
            <p>Toca para abrir tu invitación</p>
            <div class="flecha"><i class="fas fa-chevron-down"></i></div>
        </div>
    </div>

    <main class="invitacion-container active">
        <div class="marco-invitacion">
            <section class="bloque-seccion bloque-oscuro">
                <div class="contenedor-foto">
                    <img
                        src="https://torrealbaexio-prog.github.io/invitacion-boda/foto1.jpeg"
                        alt="Dayana y Exio"
                        class="foto-boda"
                        width="180"
                        height="180"
                    >
                </div>
                <h1 class="nombres-novios">Dayana</h1>
                <div class="ampersand">&amp;</div>
                <h1 class="nombres-novios">Exio</h1>
            </section>

            <div class="divisor-dorado"></div>

            <section class="bloque-seccion bloque-claro">
                <h2 class="texto-invitado">
                    ¡Hola, <span><%= invitation.primary_guest %></span>!
                </h2>

                <div class="versiculo">
                    “Si alguno prevalece contra el que está solo, dos estarán contra él,
                    pues cordón de tres dobleces no se rompe pronto.”
                    <span class="cita-versiculo">Eclesiastés 4:12</span>
                </div>

                <p class="introduccion-texto">
                    Hemos decidido unir nuestras vidas en matrimonio y nos llenaría
                    de alegría contar con su compañía.
                </p>

                <div class="lista-pases-contenedor">
                    <ul>
                        <li class="pase-item"><%= invitation.primary_guest %></li>
                        <% companions.forEach((companion) => { %>
                            <li class="pase-item"><%= companion.name %></li>
                        <% }) %>
                    </ul>
                </div>

                <p class="nota-aclaratoria">
                    * Cupos limitados. Velada exclusivamente para adultos.
                </p>
            </section>

            <div class="divisor-dorado"></div>

            <section class="bloque-seccion bloque-oscuro">
                <h3 class="subtitulo-elegante">SAVE THE DATE</h3>
                <h4 class="fecha-texto">Enero 8, 2027</h4>
                <div class="contador-display" aria-label="Cuenta regresiva para la boda">
                    <div class="unidad-tiempo">
                        <span id="dias" class="numero">--</span>
                        <span class="etiqueta">Días</span>
                    </div>
                    <div class="unidad-tiempo">
                        <span id="horas" class="numero">--</span>
                        <span class="etiqueta">Horas</span>
                    </div>
                    <div class="unidad-tiempo">
                        <span id="minutos" class="numero">--</span>
                        <span class="etiqueta">Min</span>
                    </div>
                    <div class="unidad-tiempo">
                        <span id="segundos" class="numero">--</span>
                        <span class="etiqueta">Seg</span>
                    </div>
                </div>
            </section>

            <div class="divisor-dorado"></div>

            <section class="bloque-seccion bloque-claro">
                <h3 class="subtitulo-elegante cursivo">Recepción</h3>
                <p class="datos-lugar">
                    <strong>Lugar:</strong> La Terraza del Portón, Cúcuta
                </p>
                <div class="grupo-mapas">
                    <a
                        href="https://maps.google.com/?q=La+terraza+del+porton+Cucuta"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-maps"
                    >
                        <i class="fas fa-map-marker-alt"></i>
                        Google Maps
                    </a>
                    <a
                        href="https://waze.com/ul?q=La+terraza+del+porton+Cucuta"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-waze"
                    >
                        <i class="fab fa-waze"></i>
                        Waze
                    </a>
                </div>
            </section>

            <div class="divisor-dorado"></div>

            <section class="bloque-seccion bloque-oscuro">
                <div class="contenedor-foto">
                    <img
                        src="https://torrealbaexio-prog.github.io/invitacion-boda/foto2.jpeg"
                        alt="Dayana y Exio"
                        class="foto-boda"
                        width="180"
                        height="180"
                        loading="lazy"
                    >
                </div>
                <p style="font-style:italic; font-family:var(--font-serif); text-align:center; color:var(--blanco); font-size:1.1rem;">
                    “Por encima de todo, vístanse de amor, que es el vínculo perfecto.”
                </p>
            </section>

            <div class="divisor-dorado"></div>

            <section class="bloque-seccion bloque-claro">
                <h3 class="subtitulo-elegante">DRESS CODE</h3>
                <p class="aviso-colores">
                    Respetuosamente les solicitamos reservar los siguientes colores
                    para uso exclusivo de la novia:
                </p>
                <div class="colores-prohibidos">
                    <div class="item-color"><span class="circulo-color blanco"></span>Blanco</div>
                    <div class="item-color"><span class="circulo-color verde"></span>Verde</div>
                    <div class="item-color"><span class="circulo-color beige"></span>Beige</div>
                    <div class="item-color"><span class="circulo-color azul"></span>Azul</div>
                </div>
            </section>

            <% if (invitation.is_foreign) { %>
                <div class="divisor-dorado"></div>
                <section class="bloque-seccion bloque-oscuro">
                    <h3 class="subtitulo-elegante">Transmisión Virtual</h3>
                    <div style="text-align:center;">
                        <a
                            href="https://youtube.com"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="btn btn-transmision"
                        >
                            <i class="fas fa-video"></i>
                            UNIRSE A LA TRANSMISIÓN
                        </a>
                    </div>
                </section>
            <% } %>

            <div class="divisor-dorado"></div>

            <section class="bloque-seccion bloque-claro">
                <% if (successMessage) { %>
                    <div class="result-message"><%= successMessage %></div>
                <% } %>

                <% if (errorMessage) { %>
                    <div class="result-message" style="color:#922b21;"><%= errorMessage %></div>
                <% } %>

                <% if (invitation.group_status === 'PENDING') { %>
                    <div class="response-card">
                        <h3 class="subtitulo-elegante">Confirma tu asistencia</h3>
                        <p>Selecciona los acompañantes que asistirán y luego elige una respuesta.</p>

                        <form method="post" action="/invitation/<%= invitation.id %>/respond">
                            <% if (companions.length > 0) { %>
                                <div style="margin-top:20px;">
                                    <% companions.forEach((companion) => { %>
                                        <label class="member-choice">
                                            <input
                                                type="checkbox"
                                                name="attending_companions"
                                                value="<%= companion.id %>"
                                                checked
                                            >
                                            <span><%= companion.name %> asistirá</span>
                                        </label>
                                    <% }) %>
                                </div>
                            <% } %>

                            <div class="response-buttons">
                                <button class="btn btn-confirmar" type="submit" name="status" value="CONFIRMED">
                                    <i class="fas fa-check"></i>
                                    Asistiremos
                                </button>

                                <% if (invitation.is_foreign) { %>
                                    <button class="btn btn-virtual" type="submit" name="status" value="VIRTUAL">
                                        <i class="fas fa-video"></i>
                                        Veremos la transmisión
                                    </button>
                                <% } %>

                                <button class="btn btn-reject" type="submit" name="status" value="REJECTED">
                                    <i class="fas fa-times"></i>
                                    No podremos asistir
                                </button>
                            </div>
                        </form>
                    </div>
                <% } else if (invitation.group_status === 'EXPIRED') { %>
                    <div class="result-message">
                        El plazo para responder esta invitación terminó.
                    </div>
                <% } else { %>
                    <div class="result-message">
                        Esta invitación ya fue respondida con el estado:
                        <strong><%= invitation.group_status %></strong>.
                    </div>
                <% } %>
            </section>
        </div>
    </main>

    <script src="/js/invitation.js" defer></script>
</body>
</html>
