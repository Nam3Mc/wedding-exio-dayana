{
  "version": 2,
  "functions": {
    "api/index.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "routes": [
    {
      "src": "/admin.html",
      "dest": "/public/admin.html"
    },
    {
      "src": "/invitation/(.*)",
      "dest": "/public/invitation.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}