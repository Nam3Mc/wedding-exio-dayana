{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/"
    },
    {
      "source": "/",
      "destination": "/admin.html"
    },
    {
      "source": "/invitation/:uuid",
      "destination": "/invitation.html"
    }
  ]
}